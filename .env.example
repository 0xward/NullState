# =============================================
# NULLSTATE // CELO_CHRONICLES
# Environment Variables
# =============================================
# Copy this file to .env.local and fill in your keys

# ----- GROQ AI (DM Engine) -----
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ----- TWITTER / X API (Social Combat) -----
# Get your keys at: https://developer.twitter.com
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ----- CELO / WEB3 -----
# WalletConnect Project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ----- APP CONFIG -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CELO_CHAIN_ID=42220

# ----- FIREBASE (Leaderboard & Live Feed) -----
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nullstate-35b2e.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nullstate-35b2e
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nullstate-35b2e.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ----- LEADERBOARD / EVENT INDEXING -----
# Block to start scanning PlayerRegistered logs from (set to contract deploy block for speed). Default: 0
NEXT_PUBLIC_LEADERBOARD_FROM_BLOCK=0

# Chunk size (in blocks) for RPC getLogs batching. Default: 50000
NEXT_PUBLIC_LEADERBOARD_CHUNK_SIZE=50000

# Celoscan API key (optional) — used as fallback when RPC getLogs fails
# Get an API key from https://celoscan.io/ or your preferred explorer
NEXT_PUBLIC_CELOSCAN_API_KEY=

# (Optional) tweak concurrency in code if needed (default currently 8)
# To change concurrency, edit lib/useContractPlayer.ts
