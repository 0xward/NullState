# MiniPay Mini App listing — dependency security requirement
# https://docs.minipay.xyz/getting-started/submit-your-miniapp.html#dependency-security
#
# Reject any dependency version published less than 7 days ago, to reduce
# exposure to npm supply-chain attacks (malicious versions are typically
# yanked within days of publish).
minimum-release-age=10080

# Prevent postinstall/preinstall scripts from dependencies running automatically.
ignore-scripts=true
