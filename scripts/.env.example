# NullState treasury CLI (scripts/deposit-reward.js) — copy to scripts/.env
# scripts/.env is gitignored; NEVER commit a real private key.

# The CONTRACT OWNER (deployer) private key. Must be the wallet that owns
# TreasureVaultV2 + NullStateRewardV2, or every write reverts. With or
# without the 0x prefix.
DEPLOYER_PRIVATE_KEY=

# Optional — defaults to https://forno.celo.org
# CELO_RPC_URL=

# Optional — only if your deploy used non-default contract addresses
# NEXT_PUBLIC_TREASURE_VAULT_ADDRESS=
# NEXT_PUBLIC_REWARD_CONTRACT_ADDRESS=
